<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <OutputType>Library</OutputType>
    <RootNamespace>MultiProjectDemo.UserModule</RootNamespace>
    <AssemblyName>MultiProjectDemo.UserModule</AssemblyName>
    <LangVersion>latest</LangVersion>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\WinformsMVP\WinformsMVP.csproj" />
    <ProjectReference Include="..\..\src\WinformsMVP.DependencyInjection\WinformsMVP.DependencyInjection.csproj" />
    <ProjectReference Include="..\..\src\WinformsMVP.Analyzers\WinformsMVP.Analyzers.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="obj\**" />
    <EmbeddedResource Remove="obj\**" />
    <None Remove="obj\**" />
  </ItemGroup>

</Project>
